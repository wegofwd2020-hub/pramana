# =============================================================================
# Pramana environment variables — copy this file to `.env` and fill in values.
# `.env` is gitignored. Never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=DEBUG                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production-use-a-long-random-string

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://pramana:pramana@localhost:5432/pramana
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis (Celery broker + result backend)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Auth (SSO via SAML/OIDC — values per provider)
# -----------------------------------------------------------------------------
SSO_ISSUER_URL=https://your-idp.example.com
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
JWT_ALGORITHM=RS256
JWT_AUDIENCE=pramana

# -----------------------------------------------------------------------------
# Object storage (AWS S3 or compatible)
# -----------------------------------------------------------------------------
S3_BUCKET_VIDEO=pramana-video-dev
S3_BUCKET_CERTIFICATES=pramana-certs-dev
S3_BUCKET_AUDIT_ARCHIVE=pramana-audit-dev   # Object Lock recommended in prod
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email (SMTP for notifications — SES recommended in prod)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@pramana.example.com

# -----------------------------------------------------------------------------
# Compliance defaults (overridable per course/tenant via DB)
# -----------------------------------------------------------------------------
DEFAULT_PASS_THRESHOLD_PCT=80
DEFAULT_COOLDOWN_DAYS=365
DEFAULT_MAX_ATTEMPTS=2
DEFAULT_RECORD_RETENTION_YEARS=7
